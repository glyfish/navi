# Federal Reserve Economic Data (FRED) — https://fred.stlouisfed.org/docs/api/fred/
FRED_API_KEY=your_fred_api_key_here
FRED_BASE_URL=https://api.stlouisfed.org/fred

# Bureau of Labor Statistics (BLS) — https://www.bls.gov/developers/
BLS_API_KEY=your_bls_api_key_here
BLS_BASE_URL=https://api.bls.gov/publicAPI/v2

# Tiingo end-of-day prices — https://www.tiingo.com/account/api/token
TIINGO_API_KEY=your_tiingo_api_key_here
TIINGO_BASE_URL=https://api.tiingo.com/tiingo

# Optional: MCP server URL (defaults to http://localhost:8080/sse)
